# Copy this file to .env and fill in real values
MASSIVE_API_KEY=your_massive_api_key_here

# Optional override; defaults to https://api.polygon.io
MASSIVE_API_BASE_URL=https://api.polygon.io

# Supabase persistence settings
SUPABASE_URL=https://<PROJECT-REF>.supabase.co

# Publishable key — safe to use in frontend/public clients (limited permissions).
# Found in Supabase → Settings → API → Publishable key.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Secret key — required by backend/repositories/user_repository.py to call
# the Supabase Auth Admin API (GET /auth/v1/admin/users).  Keep this secret.
# Found in Supabase → Settings → API → Secret key.
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# Direct Postgres connection string used by backend/db/manage_schema.py
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[REGION-POOLER-HOST]:5432/postgres

# Optional pooled URL for app/runtime clients
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[REGION-POOLER-HOST]:6543/postgres?pgbouncer=true
